# =============================================================================
# Data Talks — backend env. Copy to backend/.env and fill in.
# =============================================================================

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# REQUIRED in production. Used to sign JWTs AND derive the at-rest encryption
# key (HKDF) for source secrets, bot tokens, and OAuth tokens. Rotating it
# invalidates every JWT and breaks decryption of every stored secret — set
# once and keep it. The default in code is "change-me-in-production"; CI / a
# real deploy should fail fast on that string.
SECRET_KEY=change-me-in-production

# Optional explicit Fernet key (url-safe base64, exactly 32 bytes). When set,
# overrides the HKDF derivation from SECRET_KEY — useful if you want to rotate
# JWT signing without re-encrypting every stored secret.
# GITHUB_TOKEN_ENCRYPTION_KEY=

# Login mode. False = guest mode (no auth, single shared workspace).
# True = require email/password, JWT issued per organization.
ENABLE_LOGIN=false
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Public URL the app is served from. Required for CORS in production
# (otherwise only localhost origins are allowed). Example:
# APP_URL=https://datatalks.example.com
APP_URL=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Default is SQLite at backend/data_talks.db. For Postgres:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./data_talks.db

# -----------------------------------------------------------------------------
# LLM (default provider — workspaces can override per-LlmConfig)
# -----------------------------------------------------------------------------
# OpenAI / OpenAI-compatible (LiteLLM, OpenRouter, Azure OpenAI, …)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_AUDIO_MODEL=gpt-4o-mini-tts

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# LiteLLM proxy
LITELLM_BASE_URL=
LITELLM_MODEL=
LITELLM_API_KEY=
LITELLM_AUDIO_MODEL=

# Anthropic Claude (direct API)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Claude Code (OAuth flow recommended via Settings → LLM → "Login with Claude").
# Setting this env var is the headless / cloud-deploy alternative — paste a
# token issued by the OAuth flow.
# CLAUDE_CODE_OAUTH_TOKEN=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Local filesystem (default). Used as cache when S3 is configured below.
DATA_FILES_DIR=./data_files

# Optional S3-compatible object storage (recommended in production so
# uploaded files / generated charts survive redeploys).
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# SMTP (alerts + reports)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
# Google Sheets service account (raw JSON contents, not a path)
# GOOGLE_SHEETS_SERVICE_ACCOUNT={"type":"service_account",...}

# GitHub OAuth app (for source-onboarding flow / pipeline versioning)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# WhatsApp Cloud API (used by the integrated chat bot)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
